# ---- PreFlight service ----
BASE_URL=https://your-preflight-domain
DB_PATH=/data/preflight.db
TURSO_DATABASE_URL=      # optional; e.g. libsql://your-db.turso.io — set with TURSO_AUTH_TOKEN
TURSO_AUTH_TOKEN=        # to persist comparisons/reports on Turso instead of DB_PATH
PAYER_MODE=mock          # off | mock | testnet   (NEVER mainnet — refused in code)
PAYER_PRIVATE_KEY=       # throwaway EOA, testnet only; fund via faucet
MAX_PAY_PER_CALL_USDT=2
MAX_PAY_PER_DAY_USDT=10
PAYER_KILL_SWITCH=0
ALLOW_LOCAL_TARGETS=0    # 1 only for local dev against 127.0.0.1

# ---- BrokenBazaar fixture ----
BUG_PRICE=0
BUG_EMPTY=0
NETWORK=mock             # mock | base-sepolia
FACILITATOR=mock         # mock | okx
PAY_TO=0x2f7cF9d979A98d0C4Cd2c92c8DC0d9DFf4a04d2A
RESOURCE_URL=https://your-bazaar-domain/mcp/
